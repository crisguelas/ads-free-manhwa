// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Source {
  id             String           @id @default(cuid())
  key            String           @unique
  name           String
  baseUrl        String
  isEnabled      Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  follows        Follow[]
  seriesCache    SeriesCache[]
  chapterCache   ChapterCache[]
}

model Follow {
  id            String   @id @default(cuid())
  sourceId      String
  seriesSlug    String
  seriesTitle   String
  coverImageUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  source        Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, seriesSlug])
  @@index([sourceId, seriesSlug])
}

model SeriesCache {
  id            String         @id @default(cuid())
  sourceId      String
  seriesSlug    String
  title         String
  synopsis      String?
  coverImageUrl String?
  status        String?
  genres        String[]
  lastSyncedAt  DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  source        Source         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  chapters      ChapterCache[]

  @@unique([sourceId, seriesSlug])
  @@index([title])
}

model ChapterCache {
  id           String      @id @default(cuid())
  sourceId     String
  seriesSlug   String
  chapterSlug  String
  title        String
  chapterUrl   String
  chapterLabel String?
  publishedAt  DateTime?
  lastSyncedAt DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  source       Source      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  series       SeriesCache @relation(fields: [sourceId, seriesSlug], references: [sourceId, seriesSlug], onDelete: Cascade)

  @@unique([sourceId, seriesSlug, chapterSlug])
  @@index([sourceId, seriesSlug])
}
